{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/grammar.schema.json",
  "name": "zathurarc",
  "rules": {
    "file": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "_statements"
        },
        {
          "type": "BLANK"
        }
      ]
    },
    "_statements": {
      "type": "SEQ",
      "members": [
        {
          "type": "REPEAT",
          "content": {
            "type": "SEQ",
            "members": [
              {
                "type": "SYMBOL",
                "name": "_statement"
              },
              {
                "type": "SYMBOL",
                "name": "_terminator"
              }
            ]
          }
        },
        {
          "type": "SYMBOL",
          "name": "_statement"
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "_terminator"
            },
            {
              "type": "BLANK"
            }
          ]
        }
      ]
    },
    "_statement": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "set_directive"
        },
        {
          "type": "SYMBOL",
          "name": "include_directive"
        },
        {
          "type": "SYMBOL",
          "name": "map_directive"
        },
        {
          "type": "SYMBOL",
          "name": "unmap_directive"
        }
      ]
    },
    "set_directive": {
      "type": "SEQ",
      "members": [
        {
          "type": "ALIAS",
          "content": {
            "type": "STRING",
            "value": "set"
          },
          "named": true,
          "value": "command"
        },
        {
          "type": "SYMBOL",
          "name": "option"
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "int"
            },
            {
              "type": "SYMBOL",
              "name": "float"
            },
            {
              "type": "SYMBOL",
              "name": "_string"
            },
            {
              "type": "SYMBOL",
              "name": "bool"
            }
          ]
        }
      ]
    },
    "option": {
      "type": "PATTERN",
      "value": "[a-z-]+"
    },
    "_int": {
      "type": "PATTERN",
      "value": "\\d+"
    },
    "int": {
      "type": "SYMBOL",
      "name": "_int"
    },
    "float": {
      "type": "PREC",
      "value": 2,
      "content": {
        "type": "CHOICE",
        "members": [
          {
            "type": "SEQ",
            "members": [
              {
                "type": "CHOICE",
                "members": [
                  {
                    "type": "SYMBOL",
                    "name": "_int"
                  },
                  {
                    "type": "BLANK"
                  }
                ]
              },
              {
                "type": "STRING",
                "value": "."
              },
              {
                "type": "SYMBOL",
                "name": "_int"
              }
            ]
          },
          {
            "type": "SEQ",
            "members": [
              {
                "type": "SYMBOL",
                "name": "_int"
              },
              {
                "type": "STRING",
                "value": "."
              }
            ]
          }
        ]
      }
    },
    "bool": {
      "type": "CHOICE",
      "members": [
        {
          "type": "STRING",
          "value": "true"
        },
        {
          "type": "STRING",
          "value": "false"
        }
      ]
    },
    "_word": {
      "type": "PATTERN",
      "value": "([^\"'#\\s]|\\\\.)+"
    },
    "_string": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SEQ",
          "members": [
            {
              "type": "STRING",
              "value": "'"
            },
            {
              "type": "ALIAS",
              "content": {
                "type": "FIELD",
                "name": "content",
                "content": {
                  "type": "PATTERN",
                  "value": "([^']|\\\\')*"
                }
              },
              "named": true,
              "value": "string"
            },
            {
              "type": "STRING",
              "value": "'"
            }
          ]
        },
        {
          "type": "SEQ",
          "members": [
            {
              "type": "STRING",
              "value": "\""
            },
            {
              "type": "ALIAS",
              "content": {
                "type": "FIELD",
                "name": "content",
                "content": {
                  "type": "PATTERN",
                  "value": "([^\"]|\\\\\")*"
                }
              },
              "named": true,
              "value": "string"
            },
            {
              "type": "STRING",
              "value": "\""
            }
          ]
        },
        {
          "type": "ALIAS",
          "content": {
            "type": "SYMBOL",
            "name": "_word"
          },
          "named": true,
          "value": "string"
        }
      ]
    },
    "_argument": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SEQ",
          "members": [
            {
              "type": "STRING",
              "value": "'"
            },
            {
              "type": "ALIAS",
              "content": {
                "type": "FIELD",
                "name": "content",
                "content": {
                  "type": "PATTERN",
                  "value": "([^']|\\\\')*"
                }
              },
              "named": true,
              "value": "argument"
            },
            {
              "type": "STRING",
              "value": "'"
            }
          ]
        },
        {
          "type": "SEQ",
          "members": [
            {
              "type": "STRING",
              "value": "\""
            },
            {
              "type": "ALIAS",
              "content": {
                "type": "FIELD",
                "name": "content",
                "content": {
                  "type": "PATTERN",
                  "value": "([^\"]|\\\\\")*"
                }
              },
              "named": true,
              "value": "argument"
            },
            {
              "type": "STRING",
              "value": "\""
            }
          ]
        },
        {
          "type": "ALIAS",
          "content": {
            "type": "SYMBOL",
            "name": "_word"
          },
          "named": true,
          "value": "argument"
        }
      ]
    },
    "include_directive": {
      "type": "SEQ",
      "members": [
        {
          "type": "ALIAS",
          "content": {
            "type": "STRING",
            "value": "include"
          },
          "named": true,
          "value": "command"
        },
        {
          "type": "ALIAS",
          "content": {
            "type": "SYMBOL",
            "name": "_word"
          },
          "named": true,
          "value": "path"
        }
      ]
    },
    "unmap_directive": {
      "type": "SEQ",
      "members": [
        {
          "type": "ALIAS",
          "content": {
            "type": "STRING",
            "value": "unmap"
          },
          "named": true,
          "value": "command"
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "mode"
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "SYMBOL",
          "name": "key"
        }
      ]
    },
    "map_directive": {
      "type": "SEQ",
      "members": [
        {
          "type": "ALIAS",
          "content": {
            "type": "STRING",
            "value": "map"
          },
          "named": true,
          "value": "command"
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "mode"
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "SYMBOL",
          "name": "key"
        },
        {
          "type": "ALIAS",
          "content": {
            "type": "PATTERN",
            "value": "[a-z_]+"
          },
          "named": true,
          "value": "function"
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "_argument"
            },
            {
              "type": "BLANK"
            }
          ]
        }
      ]
    },
    "key": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SEQ",
          "members": [
            {
              "type": "STRING",
              "value": "<"
            },
            {
              "type": "ALIAS",
              "content": {
                "type": "PATTERN",
                "value": "[A-Z][a-zA-Z0-9-]+"
              },
              "named": true,
              "value": "key_name"
            },
            {
              "type": "STRING",
              "value": ">"
            }
          ]
        },
        {
          "type": "PATTERN",
          "value": "\\S"
        },
        {
          "type": "PATTERN",
          "value": "[^ \\n\\[\\]<>]+"
        }
      ]
    },
    "mode": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "["
        },
        {
          "type": "ALIAS",
          "content": {
            "type": "PATTERN",
            "value": "[^]]+"
          },
          "named": true,
          "value": "mode_name"
        },
        {
          "type": "STRING",
          "value": "]"
        }
      ]
    },
    "comment": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "#"
        },
        {
          "type": "PATTERN",
          "value": "[^\\n]*"
        }
      ]
    },
    "_terminator": {
      "type": "PATTERN",
      "value": "\\n"
    }
  },
  "extras": [
    {
      "type": "PATTERN",
      "value": "\\s"
    },
    {
      "type": "PATTERN",
      "value": "\\\\\\r?\\n"
    },
    {
      "type": "SYMBOL",
      "name": "comment"
    },
    {
      "type": "PATTERN",
      "value": "\\\\( |\\t|\\v|\\f)"
    }
  ],
  "conflicts": [],
  "precedences": [],
  "externals": [],
  "inline": [],
  "supertypes": [],
  "reserved": {}
}